{
  "name": "discord-frankenstein",
  "version": "0.1.0",
  "description": "Discord bot that streams movies and TV series to voice channels via Go Live",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "discord",
    "streaming",
    "video",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@lng2004/node-datachannel",
      "@seydx/node-av-win32-x64-mingw",
      "@seydx/node-av-win32-x64-msvc",
      "node-av",
      "sharp",
      "zeromq",
      "esbuild"
    ],
    "patchedDependencies": {
      "@dank074/discord-video-stream": "patches/@dank074__discord-video-stream.patch"
    }
  },
  "dependencies": {
    "@dank074/discord-video-stream": "^6.0.0",
    "discord.js": "^14.25.1",
    "discord.js-selfbot-v13": "^3.7.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
